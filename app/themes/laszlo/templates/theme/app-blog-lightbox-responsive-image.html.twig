{% set dimensions = uri|image_scale(2000)|dynamic_image_dimensions %}
{% embed 'laszlo:lightbox' with {
  uri,
  url: uri|image_scale(2000),
  lightbox_width: dimensions.width,
  lightbox_height: dimensions.height,
  responsive_image,
  alt,
} only %}
  {% block thumbnail %}
    {% set dimensions = uri|image_scale(400)|dynamic_image_dimensions %}
    {% include 'laszlo:image' with {
      src: uri|image_scale(400),
      width: dimensions.width,
      height: dimensions.height,
      alt,
      sizes: [
        '(max-width: 424px) 344px',
        '(max-width: 639px) 559px',
        '(max-width: 767px) 655px',
        '(max-width: 1023px) 911px',
        '(max-width: 1199px) 1087px',
        '944px',
      ],
      srcset: {
        '400w': uri|image_scale(400),
        '600w': uri|image_scale(600),
        '800w': uri|image_scale(800),
        '1000w': uri|image_scale(1000),
        '1200w': uri|image_scale(1200),
      }
    } only %}
  {% endblock %}
{% endembed %}
