<article{{ attributes.addClass('article-preview') }}>
  {% include 'laszlo:image' with {
    attributes: create_attribute({
      class: ['article-preview__poster'],
    }),
    src: poster_uri|image_scale_crop(200, 264),
    width: 200,
    height: 264,
    alt: title,
    sizes: [
      '(max-width: 424px) 188px',
      '(max-width: 639px) 296px',
      '(max-width: 767px) 234px',
      '(max-width: 1023px) 320px',
      '(max-width: 1199px) 378px',
      '182px',
    ],
    srcset: {
      '200w': poster_uri|image_scale_crop(200, 264),
      '300w': poster_uri|image_scale_crop(300, 400),
      '400w': poster_uri|image_scale_crop(400, 528),
      '600w': poster_uri|image_scale_crop(600, 800),
      '800w': poster_uri|image_scale_crop(800, 1064),
    }
  } only %}

  <h2 class="article-preview__title">
    <a href="{{ url }}" class="article-preview__link">
      {{ title }}
    </a>
  </h2>
</article>
